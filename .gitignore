# Python .gitignore — DemandIQ

# ── Byte-compiled / optimised / DLL files ─────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# ── Distribution / packaging ──────────────────────────────────────────────────
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env

# ── Environment variables / secrets ──────────────────────────────────────────
.env*
!.env.example
*.pem
*.key

# ── Jupyter Notebook checkpoints ──────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ── Data files (keep structure, ignore contents) ──────────────────────────────
data/raw/*
data/cleaned/*
!data/raw/.gitkeep
!data/cleaned/.gitkeep
!data/cleaned/fact_table.csv
*.csv
*.parquet
*.xlsx
*.json

# ── Model artefacts ───────────────────────────────────────────────────────────
*.pkl
*.pickle
*.joblib
*.h5
*.pt
*.pth
models/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Linting / type checking ───────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# -- forecast_preview.html

forecast_preview.html
